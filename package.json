{
  "name": "zenty",
  "version": "1.0.9",
  "description": "Zustand entity store for managing single and multiple entities",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/zentylib/zenty",
    "directory": "packages/zenty"
  },
  "bugs": {
    "url": "https://github.com/zentilib/zenty/issues"
  },
  "homepage": "https://zentylib.com",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint .",
    "prepublishOnly": "npm run lint && npm run build",
    "build": "tsup src/index.ts --dts --format esm,cjs"
  },
  "keywords": [
    "zustand",
    "state",
    "store",
    "entity",
    "crud"
  ],
  "author": "Milaim Ajdari",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "eslint": "^9.39.4",
    "eslint-plugin-jest": "^29.15.2",
    "jest": "^29.0.0",
    "react": "^18.0.0",
    "ts-jest": "^29.4.0",
    "tsup": "^8.5.1",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.61.0",
    "zustand": "^5.0.0"
  },
  "peerDependencies": {
    "react": ">=18 <20",
    "react-dom": ">=18 <20",
    "zustand": "^4.4.0 || ^5.0.0"
  }
}
